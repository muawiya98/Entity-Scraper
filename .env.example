# ---------------------------------------------------------------------------
# Entity Scraper - configuration
# Copy this file to ".env" and fill in any optional values.
# Everything works out of the box with NO keys (free DuckDuckGo search).
# ---------------------------------------------------------------------------

# Flask secret key (any random string). Used for session/flash messages.
SECRET_KEY=change-me-to-a-random-string

# Which search backend to use by default:
#   duckduckgo  -> free, no API key (default)
#   google      -> Google Programmable Search (needs GOOGLE_API_KEY + GOOGLE_CSE_ID)
#   serpapi     -> SerpAPI (needs SERPAPI_KEY)
# SEARCH_BACKEND=duckduckgo
SEARCH_BACKEND=google

# --- Optional paid backends (leave blank to ignore) ---
# Google Programmable Search Engine: https://programmablesearchengine.google.com/
GOOGLE_API_KEY=**************************************
GOOGLE_CSE_ID=********************

# SerpAPI: https://serpapi.com/
SERPAPI_KEY=

# --- Optional LLM assist layer ---
# Disabled automatically when no key is present. When enabled, the LLM is used
# after core steps for search-result ranking, backup query generation, page-link
# selection, extraction fallback, and final record normalization.
LLM_ENABLED=true
# Works with OpenAI and most OpenAI-compatible APIs.
OPENAI_API_KEY=**************************************************************
# Or use a generic key name instead of OPENAI_API_KEY:
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
#gpt-4.1-mini
LLM_MODEL=gpt-4o-mini 
LLM_TEMPERATURE=0.1
LLM_TIMEOUT=45
LLM_MAX_PAGE_CHARS=9000

HUNTER_API_KEY=******************************************
APOLLO_API_KEY=*********************************
LUSHA_API_KEY=your_lusha_api_key_here

CLAY_WEBHOOK_URL=https://api.clay.com/v3/sources/webhook/pull-in/your-unique-webhook-id

# --- Scraping behaviour ---
# Default region/country for phone parsing and search bias (ISO code, e.g. SA, AE, US)
# DEFAULT_REGION=SA
# Max internal pages to crawl per website (homepage + contact/about/team pages)
MAX_PAGES_PER_SITE=6
# HTTP request timeout in seconds
REQUEST_TIMEOUT=15
# Polite delay between requests to the same site (seconds)
REQUEST_DELAY=0.5
# Respect robots.txt (true/false)
RESPECT_ROBOTS=true
